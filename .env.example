# ===========================================================================
# GCP FREE-TIER CONFIGURATION -- copy to `.env` and fill in.  DO NOT COMMIT .env
# ===========================================================================
# Project + location. us-central1 is recommended for the widest free-tier
# coverage of Vertex AI Pipelines and the Always-Free e2-micro VM.
GCP_PROJECT_ID=my-free-tier-project
GCP_REGION=us-central1

# ---- Google Cloud Storage (Free tier: 5 GB-months in us-* regions) ----------
# Single bucket used as the KFP pipeline root AND artifact store.
GCS_BUCKET=my-free-tier-project-mlops
GCS_PIPELINE_ROOT=gs://my-free-tier-project-mlops/pipeline-root
GCS_DRIFT_PREFIX=gs://my-free-tier-project-mlops/drift-reports
GCS_MODEL_PREFIX=gs://my-free-tier-project-mlops/models

# ---- BigQuery Sandbox (Free: 10 GB storage, 1 TB query/month, no billing) ---
BQ_DATASET_RAW=demand_raw
BQ_DATASET_MART=demand_mart
BQ_LOCATION=US

# ---- Vertex AI Experiments (free metadata store) ----------------------------
VERTEX_EXPERIMENT_NAME=demand-forecasting

# ---- Service account used by Vertex AI Pipelines to run steps ----------------
# Grant: roles/aiplatform.user, roles/storage.objectAdmin, roles/bigquery.user
VERTEX_SA_EMAIL=vertex-pipelines@my-free-tier-project.iam.gserviceaccount.com

# ---- Experiment tracking backend: "vertex" or "mlflow_gcs" ------------------
TRACKING_BACKEND=vertex
MLFLOW_GCS_ARTIFACT_ROOT=gs://my-free-tier-project-mlops/mlflow
